{
  "name": "solana-stablecoin-standard",
  "version": "0.1.0",
  "description": "Open-source SDK and standards for Solana stablecoins",
  "main": "index.js",
  "workspaces": [
    "sdk/core",
    "sdk/cli",
    "services/mint-burn",
    "services/indexer",
    "services/compliance",
    "services/webhooks"
  ],
  "scripts": {
    "build": "anchor build && yarn build:sdk",
    "build:sdk": "yarn workspaces foreach -pt run build",
    "build:services": "yarn workspaces foreach -pt --include 'services/*' run build",
    "test": "anchor test",
    "test:unit": "anchor test -- --grep 'unit'",
    "test:integration": "anchor test -- --grep 'integration'",
    "deploy": "anchor deploy",
    "services": "docker compose up",
    "services:build": "docker compose build",
    "services:dev": "docker compose up --build"
  },
  "dependencies": {
    "@coral-xyz/anchor": "0.32.1",
    "@solana/spl-token": "^0.4.0",
    "@solana/web3.js": "^1.95.0",
    "borsh": "^2.0.0"
  },
  "devDependencies": {
    "@types/chai": "^4.3.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^25.3.3",
    "chai": "^4.3.0",
    "mocha": "^10.0.0",
    "ts-mocha": "^10.0.0",
    "typescript": "^5.0.0"
  }
}
