{
  "name": "solana-stablecoin-standard",
  "version": "0.1.0",
  "description": "Open-source SDK and standards for Solana stablecoins",
  "main": "index.js",
  "workspaces": [
    "sdk/core",
    "sdk/cli"
  ],
  "scripts": {
    "build": "anchor build && npm run build:sdk",
    "build:sdk": "npm run build --workspaces",
    "test": "anchor test",
    "test:unit": "anchor test -- --grep 'unit'",
    "test:integration": "anchor test -- --grep 'integration'",
    "deploy": "anchor deploy",
    "services": "docker compose up",
    "services:build": "docker compose build"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/web3.js": "^1.95.0",
    "@solana/spl-token": "^0.4.0",
    "@solana/spl-token-2022": "^0.1.0"
  },
  "devDependencies": {
    "@types/chai": "^4.3.0",
    "@types/mocha": "^10.0.0",
    "chai": "^4.3.0",
    "mocha": "^10.0.0",
    "ts-mocha": "^10.0.0",
    "typescript": "^5.0.0"
  }
}
